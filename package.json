{
  "name": "leadgen-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "all": "npm run frontend & npm run backend",
    "frontend": "cd servers/frontend && npm run dev",
    "backend": "python3 -m servers.backend.app",
    "build": "cd servers/frontend && npm run build",
    "start": "cd servers/frontend && npm start",
    "lint": "cd servers/frontend && npm run lint",
    "typecheck-frontend": "cd servers/frontend && npm run typecheck",
    "typecheck-backend": "python3 -m mypy servers/backend",
    "install-frontend": "cd servers/frontend && npm install",
    "install-backend": "cd servers/backend && pip3 install -r requirements.txt",
    "install-backend-dev": "cd servers/backend && pip3 install -r requirements-dev.txt",
    "install-all": "npm run install-frontend && npm run install-backend && npm run install-backend-dev",
    "uninstall-frontend": "cd servers/frontend && rm -rf node_modules package-lock.json",
    "uninstall-backend": "cd servers/backend && pip3 uninstall -r requirements.txt -y",
    "uninstall-backend-dev":  "pip3 uninstall -r requirements-dev.txt -y",
    "uninstall-all": "npm run uninstall-frontend && npm run uninstall-backend && npm run uninstall-backend-dev"
  }
}
