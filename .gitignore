# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Root level items (if any)
node_modules
.mypy_cache

# Frontend dependencies & build
servers/frontend/node_modules/
servers/frontend/.next/
servers/frontend/.env.local
servers/frontend/package-lock.json

# Backend dependencies & generated
servers/backend/venv/
servers/backend/__pycache__/
servers/backend/*.pyc
servers/backend/*.pyo
servers/backend/backend.log

# Backend data & secrets (should not be committed)
servers/backend/database/
servers/backend/certificates/
servers/backend/backups/

# Frontend data & secrets (should not be committed)
servers/frontend/certificates/
servers/frontend/frontend.log

# Frontend artifacts (generated by Next.js)
servers/frontend/.env.development.local
servers/frontend/.env.test.local
servers/frontend/.env.production.local
servers/frontend/tsconfig.tsbuildinfo

# Python (backend-specific)
servers/backend/*.egg-info/
servers/backend/*.egg
servers/backend/pip-log.txt
servers/backend/pip-delete-this-directory.txt
servers/backend/backend.log
servers/backend/__pycache__

# Compiled files for moved `src` package
servers/backend/src/__pycache__
servers/backend/src/*.pyc
servers/backend/src/*.pyo

# Node.js
package-lock.json
yarn.lock
npm-backend.log*
yarn-backend.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE (keep .vscode/settings.json - it has project config)
.idea/
.pylance/
*.swp
*.swo
*~
.pytest_cache/

# Misc
.env
*.pem
dist/
build/
.vercel/

# Next.js compiled output and generated JS (frontend)
servers/frontend/.next/
servers/frontend/.next/**/*
servers/frontend/.next/**/**/*.js
servers/frontend/.next/**/**/*.js.map
servers/frontend/.next/static/
servers/frontend/.next/server/
servers/frontend/out/

#Other (if any)
tools/__pycache__
servers/__pycache__