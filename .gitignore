# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Root level dependencies (if any)
node_modules/

# Frontend dependencies & build
frontend/node_modules/
frontend/.next/
frontend/.env.local
frontend/package-lock.json

# Backend dependencies & generated
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/backend.log
backend/*.log

# Backend data & secrets (should not be committed)
backend/data/
backend/certificates/
backend/backups/

# Frontend data & secrets (should not be committed)
frontend/certificates/

# Frontend artifacts (generated by Next.js)
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/tsconfig.tsbuildinfo

# Python (backend-specific)
backend/__pycache__/
backend/*.egg-info/
backend/*.egg
backend/pip-log.txt
backend/pip-delete-this-directory.txt

# Node.js
package-lock.json
yarn.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE (keep .vscode/settings.json - it has project config)
.idea/
.pylance/
*.swp
*.swo
*~

# Misc
.env
*.pem
dist/
build/
.vercel/

# Next.js compiled output and generated JS (frontend)
frontend/.next/
frontend/.next/**/*
frontend/.next/**/**/*.js
frontend/.next/**/**/*.js.map
frontend/.next/static/
frontend/.next/server/
frontend/out/
